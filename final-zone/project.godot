; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="FinalZone"
config/version="0.1.0"
run/main_scene="res://Scenes/Main/boot.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://Resources/default_bus_layout.tres"

[autoload]

SettingsManager="*res://Scripts/Managers/settings_manager.gd"
LoadoutManager="*res://Scripts/Managers/loadout_manager.gd"
CustomizeManager="*res://Scripts/Managers/customize_manager.gd"
AudioManager="*res://Scripts/Managers/audio_manager.gd"
SceneManager="*res://Scripts/Managers/scene_manager.gd"
GameManager="*res://Scripts/Managers/game_manager.gd"
MatchManager="*res://Scripts/Managers/match_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

